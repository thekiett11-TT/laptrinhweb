@{
    ViewData["Title"] = "Đăng ký chuyên ngành";
}
<h2>Đăng ký chuyên ngành</h2>

<form method="post" asp-action="ShowKQ">
    <div>
        <label>Mã số sinh viên:</label>
        <input type="text" name="MSSV" required />
    </div>
    <div>
        <label>Họ và tên:</label>
        <input type="text" name="HoTen" required />
    </div>
    <div>
        <label>Điểm trung bình:</label>
        <input type="number" step="0.1" name="DiemTB" required />
    </div>
    <div>
        <label>Chuyên ngành:</label>
        <select name="ChuyenNganh">
            <option value="CNPM">Công nghệ phần mềm</option>
            <option value="HTTT">Hệ thống thông tin</option>
            <option value="ANM">An ninh mạng</option>
            <option value="TTNT">Trí tuệ nhân tạo</option>
            <option value="MMT">Mạng máy tính</option>
        </select>
    </div>
    <button type="submit">Đăng ký</button>
</form>