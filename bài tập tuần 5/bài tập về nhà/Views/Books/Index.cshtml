@model IEnumerable<bài_tập_về_nhà.Models.Book>

@{
    ViewData["Title"] = "Trang Chủ";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="text-primary">Thêm mới</h4>
    <a asp-action="Create" class="btn btn-outline-info btn-sm">Thêm mới</a>
</div>

<div class="row">
    @foreach (var item in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-header bg-white text-center">
                    <h6 class="mb-0 fw-bold">@item.Title</h6>
                    <div class="text-end mt-1">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="text-info text-decoration-none small">Edit</a>
                    </div>
                </div>

                <div class="card-body">
                    <p class="card-text mb-1"><small><strong>Tác giả:</strong> @item.Author</small></p>
                    <p class="card-text mb-2"><small><strong>Thể loại:</strong> @(item.Category?.Name ?? "Chưa có")</small></p>

                    <div class="text-center">
                        <img src="@(string.IsNullOrEmpty(item.ImagePath) ? "/images/tải xuống.jpg" : item.ImagePath)"
                             class="img-fluid" style="height: 180px; object-fit: cover;" alt="@item.Title" />
                    </div>
                </div>

                <div class="card-footer bg-white text-end">
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm">Chi tiết</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-success btn-sm">Xóa</a>
                </div>
            </div>
        </div>
    }
</div>