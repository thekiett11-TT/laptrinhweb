@model bài_tập_về_nhà.Models.Book

@{
    ViewData["Title"] = "Chi tiết sách";
}

<h4 class="text-uppercase mb-4">THÔNG TIN CHI TIẾT SÁCH</h4>

<div class="card border-info mb-3">
    <div class="row g-0">
        <div class="col-md-4 text-center p-4">
            <img src="@(string.IsNullOrEmpty(Model.ImagePath) ? "/images/default-book.png" : Model.ImagePath)"
                 class="img-fluid rounded border" alt="@Model.Title">
        </div>

        <div class="col-md-8">
            <div class="card-body">
                <h4 class="card-title text-danger">Tên sách: @Model.Title</h4>
                <h6 class="card-subtitle mb-3 text-dark"><strong>Tác giả:</strong> @Model.Author</h6>

                <p class="card-text">
                    <strong>Mô tả:</strong> <br />
                    @Model.Description
                </p>

                <h4 class="text-danger mt-4">
                    Giá bán: @Model.Price.ToString("N0") VNĐ
                </h4>

                <div class="mt-4 d-flex align-items-center">
                    <div class="input-group me-3" style="width: 120px;">
                        <button class="btn btn-outline-secondary" type="button">-</button>
                        <input type="text" class="form-control text-center" value="1">
                        <button class="btn btn-outline-secondary" type="button">+</button>
                    </div>
                    <button class="btn btn-outline-danger me-2">
                        <i class="bi bi-cart-plus"></i> Thêm vào giỏ hàng
                    </button>
                    <button class="btn btn-danger">Đặt mua</button>
                </div>

                <div class="mt-3">
                    <a asp-action="Index" class="text-decoration-none">← Quay lại danh sách</a>
                </div>
            </div>
        </div>
    </div>
</div>